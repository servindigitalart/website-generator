---
const { name, title, specialty, bio, credentials = [] } = Astro.props;
---
<article class="doctor-card">
  <div class="doctor-photo" aria-hidden="true">
    <span class="doctor-initials">{name.split(' ').map((n: string) => n[0]).join('').slice(0,2)}</span>
  </div>
  <div class="doctor-info">
    <h3 class="doctor-name">{name}</h3>
    <p class="doctor-title">{title}</p>
    <p class="doctor-specialty">{specialty}</p>
    {credentials.length > 0 && (
      <div class="doctor-credentials" aria-label="Credentials">
        {credentials.map((c: string) => <span class="credential-badge">{c}</span>)}
      </div>
    )}
    <p class="doctor-bio">{bio}</p>
  </div>
</article>

<style>
.doctor-card {
  display: flex; flex-direction: column; align-items: center; text-align: center;
  padding: 2.5rem 2rem; background: var(--color-surface-base);
  border: 1px solid rgba(10,46,110,0.08); border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm); transition: box-shadow 0.3s;
}
.doctor-card:hover { box-shadow: var(--shadow-md); }
.doctor-photo {
  width: 120px; height: 120px; border-radius: 50%;
  background: linear-gradient(135deg, #0A2E6E, #1565C0);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 1.5rem;
  border: 4px solid var(--color-brand-accent);
}
.doctor-initials { font-family: var(--font-stats); font-size: 2rem; color: white; letter-spacing: 0.05em; }
.doctor-name { font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; color: var(--color-brand-primary); margin: 0 0 0.25rem; }
.doctor-title { font-size: 0.875rem; color: var(--color-brand-accent); font-weight: 600; margin: 0 0 0.25rem; }
.doctor-specialty { font-size: 0.875rem; color: var(--color-text-secondary); margin: 0 0 0.875rem; }
.doctor-credentials { display: flex; gap: 0.5rem; flex-wrap: wrap; justify-content: center; margin-bottom: 1rem; }
.credential-badge {
  font-size: 0.75rem; font-weight: 600; padding: 0.2rem 0.6rem;
  background: var(--color-surface-alt); color: var(--color-brand-primary);
  border-radius: 100px; border: 1px solid rgba(10,46,110,0.15);
}
.doctor-bio { font-size: 0.9rem; color: var(--color-text-secondary); line-height: 1.65; margin: 0; }
</style>
