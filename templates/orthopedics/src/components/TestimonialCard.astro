---
const { quote, patient, treatment } = Astro.props;
---
<blockquote class="testimonial-card">
  <span class="quote-mark" aria-hidden="true">"</span>
  <p class="quote-text">{quote}</p>
  <footer class="quote-attribution">
    <span class="patient-name">{patient}</span>
    <span class="treatment-tag">{treatment}</span>
  </footer>
</blockquote>

<style>
.testimonial-card {
  padding: 2.5rem; margin: 0;
  background: var(--color-surface-base);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  position: relative;
  border-top: 4px solid var(--color-brand-accent);
}
.quote-mark {
  font-family: var(--font-stats); font-size: 5rem; line-height: 0.6;
  color: var(--color-brand-accent); display: block; margin-bottom: 1rem;
}
.quote-text {
  font-size: 1.05rem; line-height: 1.75; color: var(--color-text-primary);
  font-style: italic; margin: 0 0 1.5rem;
}
.quote-attribution { display: flex; align-items: center; gap: 1rem; }
.patient-name { font-weight: 700; color: var(--color-brand-primary); font-size: 0.9375rem; }
.treatment-tag {
  font-size: 0.8rem; font-weight: 600; padding: 0.2rem 0.75rem;
  background: var(--color-surface-alt); color: var(--color-brand-accent);
  border-radius: 100px;
}
</style>
