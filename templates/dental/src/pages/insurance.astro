---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CTASection from '../components/CTASection.astro';
import site from '../content/site.json';

const insurers = ["Aetna","BlueCross BlueShield","Cigna","Delta Dental","Humana","MetLife","United Healthcare","Guardian","Principal","Ameritas","Dental Select","Sun Life"];
---
<Layout
  title={`Insurance & Billing | ${site.clinic_name}`}
  description={`${site.clinic_name} accepts most major dental insurance plans.`}
>
  <Nav />
  <section class="page-hero">
    <div class="container">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Home</a><span> / </span><span aria-current="page">Insurance</span>
      </nav>
      <h1 class="reveal">Insurance & Billing</h1>
      <p class="page-hero-sub reveal">We work with most major dental insurance plans</p>
    </div>
  </section>

  <section class="section">
    <div class="container insurance-layout">
      <div class="insurance-main">
        <div class="reveal">
          <span class="section-tag">Accepted Plans</span>
          <h2>We Accept Most Major Insurance</h2>
          <p>We're in-network with many major dental plans and will file claims on your behalf. Our team will help you maximize your benefits.</p>
        </div>
        <div class="insurers-grid reveal">
          {insurers.map(ins => <div class="insurer-chip">{ins}</div>)}
        </div>
        <div class="faq-section reveal" style="margin-top:3rem;">
          <h2>Billing FAQ</h2>
          {[
            { q: "What if I don't have insurance?", a: "We offer affordable self-pay rates and flexible payment plans to make care accessible for everyone." },
            { q: "Do you offer payment plans?", a: "Yes! We offer 0% interest payment plans through CareCredit and Sunbit for qualifying patients." },
            { q: "How do I know what's covered?", a: "Our billing team will verify your benefits before treatment and provide a detailed cost estimate." },
          ].map(faq => (
            <details class="faq-item">
              <summary class="faq-q">{faq.q}</summary>
              <p class="faq-a">{faq.a}</p>
            </details>
          ))}
        </div>
      </div>

      <aside class="insurance-sidebar">
        <div class="verify-card">
          <h3>Verify Your Benefits</h3>
          <form name="insurance-verify" method="POST" data-netlify="true">
            <input type="hidden" name="form-name" value="insurance-verify" />
            <div class="form-group"><label for="v-name">Name</label><input type="text" id="v-name" name="name" /></div>
            <div class="form-group"><label for="v-insurance">Insurance</label><input type="text" id="v-insurance" name="insurance" /></div>
            <div class="form-group"><label for="v-member-id">Member ID</label><input type="text" id="v-member-id" name="member-id" /></div>
            <div class="form-group"><label for="v-phone">Phone</label><input type="tel" id="v-phone" name="phone" /></div>
            <button type="submit" class="btn btn-primary" style="width:100%;">Verify Benefits</button>
          </form>
        </div>
      </aside>
    </div>
  </section>

  <CTASection />
  <Footer />
</Layout>

<style>
.page-hero { background: linear-gradient(135deg, #023E8A, #0077B6); padding: 10rem 0 4rem; color: white; }
.breadcrumb { font-size: 0.875rem; color: rgba(255,255,255,0.6); margin-bottom: 1.5rem; }
.breadcrumb a { color: rgba(255,255,255,0.6); }
.page-hero h1 { color: white; margin: 0 0 0.75rem; font-size: clamp(2rem, 4vw, 3.5rem); }
.page-hero-sub { color: rgba(255,255,255,0.75); font-size: 1.125rem; margin: 0; }
.insurance-layout { display: grid; grid-template-columns: 1fr 300px; gap: 4rem; align-items: start; }
.insurance-main h2 { color: var(--color-brand-secondary); margin: 1rem 0; }
.insurance-main p { color: var(--color-text-secondary); line-height: 1.8; }
.insurers-grid { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem; }
.insurer-chip { padding: 0.5rem 1rem; background: var(--color-surface-alt); border-radius: var(--radius-xl); font-size: 0.875rem; font-weight: 500; color: var(--color-brand-secondary); border: 1px solid rgba(0,180,216,0.25); }
.faq-item { border-bottom: 1px solid var(--color-surface-alt); }
.faq-q { cursor: pointer; padding: 1.25rem 0; font-weight: 600; color: var(--color-brand-secondary); list-style: none; }
.faq-q::-webkit-details-marker { display: none; }
.faq-q::before { content: '+'; margin-right: 0.75rem; color: var(--color-brand-primary); font-size: 1.25rem; }
details[open] .faq-q::before { content: '−'; }
.faq-a { padding: 0 0 1.25rem 1.5rem; color: var(--color-text-secondary); line-height: 1.75; margin: 0; }
.insurance-sidebar { position: sticky; top: 100px; }
.verify-card { background: var(--color-surface-alt); border-radius: var(--radius-lg); padding: 2rem; border-top: 4px solid var(--color-brand-primary); }
.verify-card h3 { color: var(--color-brand-secondary); margin: 0 0 1.5rem; }
.form-group { margin-bottom: 1rem; }
.form-group label { display: block; font-weight: 600; font-size: 0.8125rem; margin-bottom: 0.375rem; color: var(--color-brand-secondary); }
.form-group input { width: 100%; padding: 0.75rem 0.875rem; border: 2px solid rgba(0,180,216,0.2); border-radius: var(--radius-md); font-family: var(--font-body); outline: none; }
.form-group input:focus { border-color: var(--color-brand-primary); }
@media (max-width: 1023px) { .insurance-layout { grid-template-columns: 1fr; } .insurance-sidebar { position: static; } }
</style>
