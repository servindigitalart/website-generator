---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import site from '../content/site.json';

const siteUrl = import.meta.env.SITE || 'https://CLINIC_SUBDOMAIN.medplatform.io';
const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": site.clinic_name,
  "telephone": site.phone,
  "email": site.email,
  "address": { "@type": "PostalAddress", "streetAddress": site.address },
  "openingHours": site.hours,
  "url": siteUrl,
};
---
<Layout
  title={`Contact | ${site.clinic_name}`}
  description={`Book your dental appointment at ${site.clinic_name}. ${site.phone}.`}
  schema={schema}
>
  <Nav />
  <section class="page-hero">
    <div class="container">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Home</a><span> / </span><span aria-current="page">Contact</span>
      </nav>
      <h1 class="reveal">Book Your Appointment</h1>
      <p class="page-hero-sub reveal">We'd love to welcome you to our dental family</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <div class="reveal">
        <h2>Send Us a Message</h2>
        <form class="contact-form" name="contact" method="POST" data-netlify="true" action="/contact?success=true">
          <input type="hidden" name="form-name" value="contact" />
          <div class="form-group">
            <label for="name">Full Name *</label>
            <input type="text" id="name" name="name" required autocomplete="name" />
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required autocomplete="email" />
            </div>
            <div class="form-group">
              <label for="phone">Phone</label>
              <input type="tel" id="phone" name="phone" autocomplete="tel" />
            </div>
          </div>
          <div class="form-group">
            <label for="service">Service Interest</label>
            <select id="service" name="service">
              <option value="">Select a service</option>
              <option>Teeth Whitening</option>
              <option>Dental Implants</option>
              <option>Invisalign</option>
              <option>Emergency Care</option>
              <option>Routine Checkup</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="preferred-time">Preferred Time</label>
            <select id="preferred-time" name="preferred-time">
              <option value="">Select a preference</option>
              <option>Morning (8am–12pm)</option>
              <option>Afternoon (12pm–5pm)</option>
              <option>Any time</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="4" placeholder="How can we help you?"></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%;">Send Message</button>
        </form>
      </div>

      <aside class="contact-info reveal">
        <h2>Our Information</h2>
        <div class="info-block"><h3>Address</h3><address>{site.address}</address></div>
        <div class="info-block"><h3>Phone</h3><a href={`tel:${site.phone}`} class="info-phone">{site.phone}</a></div>
        <div class="info-block"><h3>Email</h3><a href={`mailto:${site.email}`}>{site.email}</a></div>
        <div class="info-block">
          <h3>Hours</h3>
          <table class="hours-table">
            <tbody>
              <tr><td>Monday – Friday</td><td>8:00 AM – 5:00 PM</td></tr>
              <tr><td>Saturday</td><td>9:00 AM – 2:00 PM</td></tr>
              <tr><td>Sunday</td><td>Closed</td></tr>
            </tbody>
          </table>
        </div>
        <div class="map-placeholder" aria-label="Map placeholder"><span>Map</span></div>
      </aside>
    </div>
  </section>
  <Footer />
</Layout>

<style>
.page-hero { background: linear-gradient(135deg, #023E8A, #0077B6); padding: 10rem 0 4rem; color: white; }
.breadcrumb { font-size: 0.875rem; color: rgba(255,255,255,0.6); margin-bottom: 1.5rem; }
.breadcrumb a { color: rgba(255,255,255,0.6); }
.page-hero h1 { color: white; margin: 0 0 0.75rem; font-size: clamp(2rem, 4vw, 3.5rem); }
.page-hero-sub { color: rgba(255,255,255,0.75); font-size: 1.125rem; margin: 0; }
.contact-grid { display: grid; grid-template-columns: 1fr 380px; gap: 5rem; align-items: start; }
.contact-grid h2 { color: var(--color-brand-secondary); margin: 0 0 2rem; }
.form-group { margin-bottom: 1.5rem; }
.form-group label { display: block; font-weight: 600; font-size: 0.875rem; margin-bottom: 0.5rem; color: var(--color-brand-secondary); }
.form-group input, .form-group select, .form-group textarea {
  width: 100%; padding: 0.875rem 1rem;
  border: 2px solid var(--color-surface-alt); border-radius: var(--radius-md);
  font-family: var(--font-body); font-size: 1rem; color: var(--color-text-primary);
  background: white; transition: border-color 0.2s; outline: none;
}
.form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: var(--color-brand-primary); }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.info-block { margin-bottom: 2rem; }
.info-block h3 { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-brand-primary); margin: 0 0 0.5rem; }
.info-block address { font-style: normal; color: var(--color-text-secondary); line-height: 1.7; }
.info-block a { color: var(--color-text-secondary); transition: color 0.2s; }
.info-block a:hover { color: var(--color-brand-primary); }
.info-phone { font-size: 1.375rem; font-weight: 700; color: var(--color-brand-primary) !important; }
.hours-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
.hours-table td { padding: 0.375rem 0; color: var(--color-text-secondary); }
.hours-table td:last-child { text-align: right; }
.map-placeholder { height: 200px; border-radius: var(--radius-lg); background: var(--color-surface-alt); display: flex; align-items: center; justify-content: center; border: 2px dashed rgba(0,180,216,0.3); color: var(--color-text-secondary); font-size: 0.875rem; margin-top: 1rem; }
@media (max-width: 1023px) { .contact-grid { grid-template-columns: 1fr; gap: 3rem; } }
@media (max-width: 639px) { .form-row { grid-template-columns: 1fr; } }
</style>
