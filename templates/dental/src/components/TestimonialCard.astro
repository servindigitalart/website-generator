---
const { quote, patient, treatment, rating = 5 } = Astro.props;
---
<blockquote class="testimonial-card">
  <div class="stars" aria-label={`${rating} out of 5 stars`}>
    {'★'.repeat(rating)}
  </div>
  <p class="quote-text">"{quote}"</p>
  <footer class="attribution">
    <span class="patient-name">{patient}</span>
    <span class="treatment-tag">{treatment}</span>
  </footer>
</blockquote>

<style>
.testimonial-card {
  padding: 2.5rem; margin: 0;
  background: white; border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  border-left: 4px solid var(--color-brand-primary);
}
.stars { color: #FFB800; font-size: 1.25rem; margin-bottom: 1rem; letter-spacing: 2px; }
.quote-text {
  font-size: 1.025rem; line-height: 1.75; color: var(--color-text-primary);
  font-style: italic; margin: 0 0 1.5rem;
}
.attribution { display: flex; align-items: center; gap: 0.875rem; flex-wrap: wrap; }
.patient-name { font-weight: 700; color: var(--color-brand-secondary); font-size: 0.9375rem; }
.treatment-tag {
  font-size: 0.8rem; font-weight: 600; padding: 0.2rem 0.75rem;
  background: var(--color-surface-alt); color: var(--color-brand-primary);
  border-radius: var(--radius-xl);
}
</style>
