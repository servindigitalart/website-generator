---
const { name, title, specialty, bio } = Astro.props;
---
<article class="doctor-card">
  <div class="doctor-photo" aria-hidden="true">
    <span class="doctor-initials">{name.split(' ').map((n: string) => n[0]).join('').slice(0,2)}</span>
  </div>
  <div class="doctor-info">
    <h3 class="doctor-name">{name}</h3>
    <p class="doctor-title">{title}</p>
    <p class="doctor-specialty">{specialty}</p>
    <p class="doctor-bio">{bio}</p>
  </div>
</article>

<style>
.doctor-card {
  display: flex; flex-direction: column; align-items: center; text-align: center;
  padding: 2.5rem 2rem; background: white;
  border-radius: var(--radius-lg); box-shadow: var(--shadow-md);
  transition: transform 0.3s;
}
.doctor-card:hover { transform: translateY(-6px); }
.doctor-photo {
  width: 110px; height: 110px; border-radius: 50%;
  background: linear-gradient(135deg, #00B4D8, #023E8A);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 1.5rem;
  border: 4px solid var(--color-surface-alt);
  box-shadow: 0 0 0 4px var(--color-brand-primary);
}
.doctor-initials { font-size: 1.75rem; font-weight: 700; color: white; }
.doctor-name { font-size: 1.25rem; font-weight: 700; color: var(--color-brand-secondary); margin: 0 0 0.25rem; }
.doctor-title { font-size: 0.875rem; color: var(--color-brand-primary); font-weight: 600; margin: 0 0 0.25rem; }
.doctor-specialty { font-size: 0.875rem; color: var(--color-text-secondary); margin: 0 0 0.875rem; }
.doctor-bio { font-size: 0.9rem; color: var(--color-text-secondary); line-height: 1.65; margin: 0; }
</style>
