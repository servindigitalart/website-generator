---
import site from '../content/site.json';
const {
  headline = 'Begin Your Transformation',
  subtext = 'Exclusive medical aesthetics. Personalized to you.',
  ctaLabel = 'Begin Your Journey',
  ctaHref = '/contact',
} = Astro.props;
---
<section class="cta-section hero-bg">
  <div class="container cta-inner">
    <div class="gold-rule reveal" style="margin-bottom:2rem;"></div>
    <p class="cta-overline reveal">Medical Aesthetics</p>
    <h2 class="cta-headline reveal">{headline}</h2>
    <p class="cta-sub reveal">{subtext}</p>
    <a href={ctaHref} class="btn btn-ghost cta-btn cta-magnetic reveal">{ctaLabel}</a>
  </div>
</section>

<style>
.cta-section { padding: 8rem 0; position: relative; overflow: hidden; }
.cta-inner { text-align: center; max-width: 640px; margin: 0 auto; }
.cta-overline { font-size: 0.6875rem; letter-spacing: 0.4em; text-transform: uppercase; color: var(--color-text-gold); margin: 0 0 1.5rem; font-family: var(--font-body); }
.cta-headline {
  font-family: var(--font-display); font-size: clamp(2.25rem, 4vw, 4rem);
  font-style: italic; color: var(--color-text-primary); margin: 0 0 1.25rem;
}
.cta-sub { font-family: var(--font-caption); font-style: italic; color: var(--color-text-secondary); font-size: 1.125rem; margin: 0 0 3rem; }
.cta-btn { margin: 0 auto; }
</style>
