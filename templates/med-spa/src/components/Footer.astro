---
import site from '../content/site.json';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-top container">
    <div class="footer-brand">
      <p class="footer-logo-text">{site.clinic_name}</p>
      <p class="footer-tagline">{site.tagline}</p>
      <div class="footer-socials" aria-label="Social media links">
        <a href="#" aria-label="Instagram" class="social-link">ig</a>
        <a href="#" aria-label="Facebook" class="social-link">fb</a>
        <a href="#" aria-label="Pinterest" class="social-link">pt</a>
      </div>
    </div>
    <div class="footer-col">
      <h3 class="footer-heading">Treatments</h3>
      <ul class="footer-list" role="list">
        {site.services.slice(0,5).map((s: any) => (
          <li><a href={`/services/${s.page_slug || s.name.toLowerCase().replace(/\s+/g,'-')}`}>{s.name}</a></li>
        ))}
        {site.services.length === 0 && (
          <>
            <li><a href="/services">Botox & Fillers</a></li>
            <li><a href="/services">Laser Resurfacing</a></li>
            <li><a href="/services">Chemical Peels</a></li>
            <li><a href="/services">Body Contouring</a></li>
          </>
        )}
      </ul>
    </div>
    <div class="footer-col">
      <h3 class="footer-heading">Hours</h3>
      <p class="footer-hours">{site.hours}</p>
      <h3 class="footer-heading" style="margin-top:1.5rem">Studio</h3>
      <ul class="footer-list" role="list">
        <li><a href="/about">Our Story</a></li>
        <li><a href="/team">Our Team</a></li>
        <li><a href="/patient-info">Client Info</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h3 class="footer-heading">Contact</h3>
      <address class="footer-address">
        <p>{site.address}</p>
        <p><a href={`tel:${site.phone}`}>{site.phone}</a></p>
        <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
      </address>
      <a href="/contact" class="btn btn-ghost" style="margin-top:1.5rem;display:inline-flex;">Book Now</a>
    </div>
  </div>
  <div class="footer-bottom container">
    <p>&copy; {year} {site.clinic_name}. All rights reserved.</p>
    <ul role="list">
      <li><a href="/privacy">Privacy</a></li>
      <li><a href="/terms">Terms</a></li>
      <li><a href="/accessibility">Accessibility</a></li>
    </ul>
  </div>
</footer>

<style>
.site-footer { background: var(--color-surface-base); border-top: 1px solid rgba(201,169,110,0.2); color: var(--color-text-secondary); font-size: 0.9rem; }
.footer-top {
  display: grid; grid-template-columns: 1.4fr 1fr 1fr 1.2fr;
  gap: 3rem; padding-top: 5rem; padding-bottom: 4rem;
}
.footer-logo-text { font-family: var(--font-display); font-size: 1.5rem; font-weight: 400; color: var(--color-text-primary); margin: 0 0 0.5rem; letter-spacing: 0.05em; }
.footer-tagline { color: var(--color-text-gold); margin: 0 0 1.5rem; font-family: var(--font-caption); font-style: italic; }
.footer-socials { display: flex; gap: 0.75rem; }
.social-link {
  width: 36px; height: 36px;
  border: 1px solid rgba(201,169,110,0.3);
  display: flex; align-items: center; justify-content: center;
  font-size: 0.625rem; letter-spacing: 0.05em; text-transform: uppercase;
  transition: var(--transition-base);
}
.social-link:hover { border-color: var(--color-text-gold); color: var(--color-text-gold); }
.footer-heading { font-family: var(--font-body); font-size: 0.625rem; font-weight: 400; letter-spacing: 0.25em; text-transform: uppercase; color: var(--color-text-gold); margin: 0 0 1rem; }
.footer-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.7rem; }
.footer-list a { color: var(--color-text-secondary); transition: color 0.2s; font-size: 0.875rem; }
.footer-list a:hover { color: var(--color-text-gold); }
.footer-hours { color: var(--color-text-secondary); line-height: 1.8; margin: 0; font-size: 0.875rem; }
.footer-address { font-style: normal; line-height: 1.9; color: var(--color-text-secondary); font-size: 0.875rem; }
.footer-address a { transition: color 0.2s; }
.footer-address a:hover { color: var(--color-text-gold); }
.footer-bottom {
  display: flex; justify-content: space-between; align-items: center;
  padding-top: 1.5rem; padding-bottom: 2rem;
  border-top: 1px solid rgba(201,169,110,0.1);
  font-size: 0.75rem; color: rgba(245,240,232,0.3);
  letter-spacing: 0.05em;
}
.footer-bottom ul { list-style: none; padding: 0; margin: 0; display: flex; gap: 1.5rem; }
.footer-bottom a { color: inherit; transition: color 0.2s; }
.footer-bottom a:hover { color: var(--color-text-gold); }
@media (max-width: 1023px) { .footer-top { grid-template-columns: 1fr 1fr; gap: 2rem; } }
@media (max-width: 639px) { .footer-top { grid-template-columns: 1fr; } .footer-bottom { flex-direction: column; gap: 1rem; text-align: center; } }
</style>
