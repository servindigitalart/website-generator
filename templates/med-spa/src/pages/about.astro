---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CTASection from '../components/CTASection.astro';
import site from '../content/site.json';
---
<Layout title={`About | ${site.clinic_name}`} description={`The story behind ${site.clinic_name} — our philosophy and commitment to aesthetic excellence.`}>
  <Nav />
  <section class="page-hero">
    <div class="container">
      <nav aria-label="Breadcrumb" class="breadcrumb"><a href="/">Home</a><span> / </span><span aria-current="page">About</span></nav>
      <span class="page-overline">Our Philosophy</span>
      <h1 class="reveal">The Story</h1>
    </div>
  </section>

  <section class="section">
    <div class="container story-grid">
      <div class="story-text reveal">
        <div class="gold-rule" style="margin-bottom:2rem;"></div>
        <h2>{site.clinic_name}</h2>
        <p class="story-lead">We believe true beauty enhancement is an art form — one that requires both medical precision and an intimate understanding of individual aesthetics.</p>
        <p>Founded by board-certified physicians with a passion for refined results, {site.clinic_name} was created as a sanctuary where science and artistry converge. We are not a volume practice. We are your partners in a personal transformation journey.</p>
        <p>Every treatment is bespoke. Every result is discreet. Every client experience is exceptional.</p>
      </div>
      <div class="story-image reveal" aria-hidden="true">
        <div class="image-placeholder"></div>
      </div>
    </div>
  </section>

  <section class="section values-section">
    <div class="container">
      <header class="section-header reveal">
        <span class="section-tag">Our Principles</span>
        <h2 style="font-style:italic;">What We Believe</h2>
        <div class="gold-rule" style="margin:0 auto;"></div>
      </header>
      <div class="values-grid">
        {[
          { title: "Artistry Over Volume", desc: "We take fewer clients to give each one the time and attention their transformation deserves." },
          { title: "Natural Results Only", desc: "Our philosophy is enhancement, not alteration. Your features, refined." },
          { title: "Medical Excellence", desc: "Every treatment is performed to the highest clinical standards by board-certified specialists." },
        ].map(v => (
          <div class="value-card reveal">
            <div class="gold-rule" style="margin-bottom:1.5rem;"></div>
            <h3>{v.title}</h3>
            <p>{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
  <Footer />
</Layout>

<style>
.page-hero {
  background: linear-gradient(45deg, #1A1A2E, #2D1F5E, #1A1A2E, #0F0F1A);
  background-size: 400% 400%; animation: gradientShift 8s ease infinite;
  padding: 10rem 0 4rem;
}
.breadcrumb { font-size: 0.75rem; color: rgba(245,240,232,0.4); margin-bottom: 1.5rem; }
.breadcrumb a { color: rgba(245,240,232,0.4); }
.page-overline { font-size: 0.625rem; letter-spacing: 0.4em; text-transform: uppercase; color: var(--color-text-gold); display: block; margin-bottom: 1rem; }
.page-hero h1 { font-family: var(--font-display); font-style: italic; color: var(--color-text-primary); margin: 0; }
.story-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; }
.story-text h2 { font-family: var(--font-display); font-size: 2rem; color: var(--color-text-primary); margin: 0 0 1.5rem; letter-spacing: 0.05em; }
.story-lead { font-family: var(--font-caption); font-style: italic; font-size: 1.25rem; color: var(--color-text-gold); line-height: 1.65; margin-bottom: 1.5rem; }
.story-text p { color: var(--color-text-secondary); line-height: 1.85; margin-bottom: 1.25rem; font-size: 0.9375rem; }
.image-placeholder { height: 500px; background: linear-gradient(135deg, #1A1A2E, #252538); border-top: 1px solid rgba(201,169,110,0.3); }
.values-section { background: var(--color-surface-alt); }
.values-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 3rem; }
.value-card { padding: 2.5rem 0; }
.value-card h3 { font-family: var(--font-display); color: var(--color-text-primary); margin: 0 0 1rem; font-size: 1.25rem; font-weight: 400; }
.value-card p { color: var(--color-text-secondary); line-height: 1.75; margin: 0; font-size: 0.9rem; }
@media (max-width: 1023px) { .story-grid { grid-template-columns: 1fr; gap: 3rem; } .values-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 639px) { .values-grid { grid-template-columns: 1fr; } }
</style>
