---
interface Props {
  name: string;
  title?: string;
  specialty?: string;
  bio?: string;
  photo_url?: string;
}
const { name, title, specialty, bio, photo_url } = Astro.props;
---
<article class="doctor-card">
  <div class="doctor-photo" aria-hidden="true">
    {photo_url
      ? <img src={photo_url} alt={name} width="220" height="220" />
      : <div class="photo-placeholder"><svg viewBox="0 0 24 24" fill="currentColor" width="48" height="48"><path fill-rule="evenodd" d="M7.5 6a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM3.751 20.105a8.25 8.25 0 0116.498 0 .75.75 0 01-.437.695A18.683 18.683 0 0112 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 01-.437-.695z" clip-rule="evenodd" /></svg></div>
    }
  </div>
  <div class="doctor-info">
    <h3 class="doctor-name">{name}</h3>
    {title && <p class="doctor-title">{title}</p>}
    {specialty && <p class="doctor-specialty">{specialty}</p>}
    {bio && <p class="doctor-bio">{bio}</p>}
  </div>
</article>

<style>
.doctor-card {
  background: var(--color-surface-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition: box-shadow var(--transition), transform var(--transition);
}
.doctor-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-3px); }
.doctor-photo { aspect-ratio: 4/3; overflow: hidden; background: var(--color-surface-alt); }
.doctor-photo img { width: 100%; height: 100%; object-fit: cover; }
.photo-placeholder {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, #EBF4FF, #DBEAFE);
  color: #93C5FD;
}
.doctor-info { padding: 1.5rem; }
.doctor-name { font-size: 1.125rem; font-weight: 700; margin-bottom: 0.25rem; }
.doctor-title { font-size: 0.8125rem; font-weight: 600; color: var(--color-brand-primary); margin-bottom: 0.25rem; }
.doctor-specialty { font-size: 0.8125rem; color: var(--color-text-muted); margin-bottom: 0.875rem; }
.doctor-bio { font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.65; margin: 0; }
</style>
