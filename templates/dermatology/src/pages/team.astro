---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CTASection from '../components/CTASection.astro';
import site from '../content/site.json';

const defaultDoctors = [
  { name: "Dr. Sarah Chen", title: "MD, FAAD", specialty: "Board-Certified Dermatologist", bio: "Dr. Chen brings 15 years of expertise in both cosmetic and medical dermatology. She trained at Johns Hopkins and completed her dermatology residency at NYU.", credentials: ["FAAD", "AAD Member"], photo_url: "" },
  { name: "Dr. Marcus Reed", title: "MD", specialty: "Cosmetic Dermatology", bio: "Specializing in laser treatments and injectables, Dr. Reed is passionate about helping patients achieve their aesthetic goals with natural-looking results.", credentials: ["AAD Member"], photo_url: "" },
  { name: "Dr. Priya Nair", title: "MD, PhD", specialty: "Mohs Surgery", bio: "Fellowship-trained in Mohs micrographic surgery, Dr. Nair offers the gold standard in skin cancer treatment with exceptional tissue preservation.", credentials: ["ACMS Fellow", "AAD Member"], photo_url: "" },
];
const doctors = site.doctors.length > 0 ? site.doctors : defaultDoctors;

const schemaPhysicians = doctors.map((d: any) => ({
  "@type": "Physician",
  "name": d.name,
  "description": d.bio,
  "medicalSpecialty": d.specialty,
  "worksFor": { "@type": "MedicalOrganization", "name": site.clinic_name },
}));
const schema = { "@context": "https://schema.org", "@graph": schemaPhysicians };
---
<Layout
  title={`Our Team | ${site.clinic_name}`}
  description={`Meet the board-certified dermatologists at ${site.clinic_name}.`}
  schema={schema}
>
  <Nav />
  <section class="page-hero">
    <div class="container">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Home</a> <span> / </span> <span aria-current="page">Our Team</span>
      </nav>
      <h1 class="reveal">Meet Our Team</h1>
      <p class="page-hero-sub reveal">Board-certified specialists dedicated to your skin health</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="team-grid">
        {doctors.map((d: any) => {
          const initials = d.name.split(' ').map((n: string) => n[0]).join('').slice(0,2);
          return (
            <article class="team-card reveal" aria-label={d.name}>
              <div class="team-photo">
                {d.photo_url
                  ? <img src={d.photo_url} alt={`Photo of ${d.name}`} width="240" height="240" loading="lazy"/>
                  : <span class="team-initials" aria-hidden="true">{initials}</span>
                }
              </div>
              <div class="team-info">
                <h2 class="team-name">{d.name}</h2>
                {d.title && <p class="team-title">{d.title}</p>}
                {d.specialty && <p class="team-specialty">{d.specialty}</p>}
                {d.credentials && d.credentials.length > 0 && (
                  <ul class="team-creds" role="list">
                    {d.credentials.map((c: string) => <li>{c}</li>)}
                  </ul>
                )}
                <details class="team-bio-toggle">
                  <summary>Read Bio</summary>
                  <p class="team-bio">{d.bio}</p>
                </details>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>
  <CTASection />
  <Footer />
</Layout>

<style>
.page-hero {
  background: linear-gradient(135deg, #4A3F7A, #2D1F5E);
  padding: 10rem 0 4rem; color: white;
}
.breadcrumb { font-size: 0.875rem; color: rgba(255,255,255,0.6); margin-bottom: 1.5rem; }
.breadcrumb a { color: rgba(255,255,255,0.6); }
.page-hero h1 { color: white; margin: 0 0 0.75rem; font-size: clamp(2.25rem, 4vw, 3.5rem); }
.page-hero-sub { color: rgba(255,255,255,0.75); margin: 0; }
.team-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.5rem; }
.team-card {
  background: var(--color-surface-base);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: box-shadow 0.3s;
}
.team-card:hover { box-shadow: var(--shadow-md); }
.team-photo {
  height: 280px;
  background: linear-gradient(135deg, var(--color-brand-primary), #6B5FA5);
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.team-photo img { width: 100%; height: 100%; object-fit: cover; }
.team-initials { font-family: var(--font-display); font-size: 4rem; color: rgba(255,255,255,0.6); }
.team-info { padding: 2rem; }
.team-name { font-family: var(--font-display); font-size: 1.375rem; color: var(--color-brand-primary); margin: 0 0 0.25rem; }
.team-title { color: var(--color-brand-secondary); font-weight: 600; font-size: 0.875rem; margin: 0 0 0.25rem; }
.team-specialty { color: var(--color-text-secondary); font-size: 0.875rem; margin: 0 0 1rem; }
.team-creds { list-style: none; padding: 0; margin: 0 0 1.25rem; display: flex; flex-wrap: wrap; gap: 0.375rem; }
.team-creds li { font-size: 0.75rem; padding: 0.25rem 0.625rem; background: var(--color-brand-accent); color: var(--color-brand-primary); border-radius: 100px; }
.team-bio-toggle summary { cursor: pointer; font-weight: 600; font-size: 0.875rem; color: var(--color-brand-primary); }
.team-bio-toggle summary::-webkit-details-marker { display: none; }
.team-bio { color: var(--color-text-secondary); font-size: 0.9rem; line-height: 1.7; margin-top: 0.75rem; }
@media (max-width: 1023px) { .team-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 639px) { .team-grid { grid-template-columns: 1fr; } }
</style>
