---
import site from '../content/site.json';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-top container">
    <div class="footer-brand">
      <p class="footer-logo-text">{site.clinic_name}</p>
      <p class="footer-tagline">{site.tagline}</p>
      <div class="footer-socials" aria-label="Social media links">
        <a href="#" aria-label="Facebook" class="social-link">f</a>
        <a href="#" aria-label="Instagram" class="social-link">in</a>
        <a href="#" aria-label="Twitter" class="social-link">tw</a>
      </div>
    </div>
    <div class="footer-col">
      <h3 class="footer-heading">Services</h3>
      <ul class="footer-list" role="list">
        {site.services.slice(0,6).map((s: any) => (
          <li><a href={`/services/${s.page_slug || s.name.toLowerCase().replace(/\s+/g,'-')}`}>{s.name}</a></li>
        ))}
        {site.services.length === 0 && (
          <>
            <li><a href="/services">Skin Treatments</a></li>
            <li><a href="/services">Acne Care</a></li>
            <li><a href="/services">Anti-Aging</a></li>
            <li><a href="/services">Cosmetic Dermatology</a></li>
          </>
        )}
      </ul>
    </div>
    <div class="footer-col">
      <h3 class="footer-heading">Hours</h3>
      <p class="footer-hours">{site.hours}</p>
      <h3 class="footer-heading" style="margin-top:1.5rem">Quick Links</h3>
      <ul class="footer-list" role="list">
        <li><a href="/about">About Us</a></li>
        <li><a href="/team">Our Team</a></li>
        <li><a href="/patient-info">Patient Info</a></li>
        <li><a href="/insurance">Insurance</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h3 class="footer-heading">Contact</h3>
      <address class="footer-address">
        <p>{site.address}</p>
        <p><a href={`tel:${site.phone}`}>{site.phone}</a></p>
        <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
      </address>
      <a href="/contact" class="btn btn-gold" style="margin-top:1.5rem;">Book Appointment</a>
    </div>
  </div>
  <div class="footer-bottom container">
    <p>&copy; {year} {site.clinic_name}. All rights reserved.</p>
    <ul role="list">
      <li><a href="/privacy">Privacy Policy</a></li>
      <li><a href="/terms">Terms of Use</a></li>
      <li><a href="/accessibility">Accessibility</a></li>
    </ul>
  </div>
</footer>

<style>
.site-footer {
  background: #1A1530;
  color: rgba(255,255,255,0.7);
  font-size: 0.9375rem;
}
.footer-top {
  display: grid;
  grid-template-columns: 1.4fr 1fr 1fr 1.2fr;
  gap: 3rem;
  padding-top: 5rem;
  padding-bottom: 4rem;
}
.footer-logo-text {
  font-family: var(--font-display);
  font-size: 1.5rem; color: white;
  margin: 0 0 0.5rem;
}
.footer-tagline { color: var(--color-brand-secondary); margin: 0 0 1.5rem; font-style: italic; }
.footer-socials { display: flex; gap: 0.75rem; }
.social-link {
  width: 36px; height: 36px; border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.2);
  display: flex; align-items: center; justify-content: center;
  font-size: 0.75rem; transition: var(--transition-base);
}
.social-link:hover { border-color: var(--color-brand-secondary); color: var(--color-brand-secondary); }
.footer-heading {
  font-family: var(--font-body); font-size: 0.75rem; font-weight: 600;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--color-brand-secondary); margin: 0 0 1rem;
}
.footer-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem; }
.footer-list a { color: rgba(255,255,255,0.65); transition: color 0.2s; }
.footer-list a:hover { color: var(--color-brand-secondary); }
.footer-hours { color: rgba(255,255,255,0.65); line-height: 1.8; margin: 0; }
.footer-address { font-style: normal; line-height: 1.9; color: rgba(255,255,255,0.65); }
.footer-address a { transition: color 0.2s; }
.footer-address a:hover { color: var(--color-brand-secondary); }
.footer-bottom {
  display: flex; justify-content: space-between; align-items: center;
  padding-top: 1.5rem; padding-bottom: 2rem;
  border-top: 1px solid rgba(255,255,255,0.1);
  font-size: 0.8125rem; color: rgba(255,255,255,0.4);
}
.footer-bottom ul { list-style: none; padding: 0; margin: 0; display: flex; gap: 1.5rem; }
.footer-bottom a { color: inherit; transition: color 0.2s; }
.footer-bottom a:hover { color: var(--color-brand-secondary); }
@media (max-width: 1023px) {
  .footer-top { grid-template-columns: 1fr 1fr; gap: 2rem; }
}
@media (max-width: 639px) {
  .footer-top { grid-template-columns: 1fr; }
  .footer-bottom { flex-direction: column; gap: 1rem; text-align: center; }
}
</style>
