---
const { quote, patient, treatment } = Astro.props;
---
<blockquote class="testimonial-card reveal">
  <svg class="quote-mark" width="48" height="36" viewBox="0 0 48 36" fill="none" aria-hidden="true">
    <path d="M0 36V21.6C0 9.6 7.2 2.4 21.6 0L24 4.8C16.8 6.4 13.2 10.4 12 16.8H21.6V36H0ZM26.4 36V21.6C26.4 9.6 33.6 2.4 48 0L50.4 4.8C43.2 6.4 39.6 10.4 38.4 16.8H48V36H26.4Z" fill="currentColor" opacity="0.3"/>
  </svg>
  <p class="testimonial-quote">{quote}</p>
  <footer class="testimonial-attribution">
    <span class="rule-gold" aria-hidden="true"></span>
    <cite>
      <strong>{patient}</strong>
      {treatment && <span> &mdash; {treatment}</span>}
    </cite>
  </footer>
</blockquote>

<style>
.testimonial-card {
  padding: 3rem 2.5rem;
  background: var(--color-surface-base);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  position: relative;
}
.quote-mark {
  color: var(--color-brand-secondary);
  margin-bottom: 1.25rem;
}
.testimonial-quote {
  font-family: var(--font-display); font-style: italic;
  font-size: clamp(1.125rem, 2vw, 1.375rem);
  line-height: 1.65; color: var(--color-text-primary);
  margin: 0 0 1.5rem;
}
.testimonial-attribution {
  display: flex; align-items: center; gap: 1rem;
  font-style: normal;
}
.rule-gold { display: block; width: 40px; height: 2px; background: var(--color-brand-secondary); flex-shrink: 0; }
cite { font-style: normal; color: var(--color-text-secondary); font-size: 0.9rem; }
cite strong { color: var(--color-text-primary); display: block; }
</style>
