---
const { name, title, specialty, bio, photo_url, credentials = [] } = Astro.props;
const initials = name.split(' ').map((n: string) => n[0]).join('').slice(0,2);
---
<article class="doctor-card reveal" aria-label={`Dr. ${name}`}>
  <div class="doctor-photo">
    {photo_url
      ? <img src={photo_url} alt={`Photo of ${name}`} width="200" height="200" loading="lazy" />
      : <span class="doctor-initials" aria-hidden="true">{initials}</span>
    }
  </div>
  <div class="doctor-info">
    <h3 class="doctor-name">{name}</h3>
    {title && <p class="doctor-title">{title}</p>}
    {specialty && <p class="doctor-specialty">{specialty}</p>}
    {credentials.length > 0 && (
      <ul class="doctor-credentials" role="list">
        {credentials.map((c: string) => <li>{c}</li>)}
      </ul>
    )}
    {bio && <p class="doctor-bio">{bio}</p>}
  </div>
</article>

<style>
.doctor-card {
  text-align: center;
  padding: 2.5rem 1.5rem;
  background: var(--color-surface-base);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  transition: box-shadow 0.3s ease;
}
.doctor-card:hover { box-shadow: var(--shadow-md); }
.doctor-photo {
  width: 160px; height: 160px; border-radius: 50%;
  margin: 0 auto 1.5rem;
  background: linear-gradient(135deg, var(--color-brand-primary), #6B5FA5);
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.doctor-photo img { width: 100%; height: 100%; object-fit: cover; }
.doctor-initials {
  font-family: var(--font-display); font-size: 2.5rem;
  color: white; font-weight: 600;
}
.doctor-name {
  font-family: var(--font-display); font-size: 1.375rem;
  color: var(--color-brand-primary); margin: 0 0 0.25rem;
}
.doctor-title { color: var(--color-brand-secondary); font-weight: 600; font-size: 0.875rem; margin: 0 0 0.25rem; }
.doctor-specialty { color: var(--color-text-secondary); font-size: 0.875rem; margin: 0 0 1rem; }
.doctor-credentials {
  list-style: none; padding: 0; margin: 0 0 1rem;
  display: flex; flex-wrap: wrap; justify-content: center; gap: 0.375rem;
}
.doctor-credentials li {
  font-size: 0.75rem; padding: 0.25rem 0.625rem;
  background: var(--color-brand-accent);
  color: var(--color-brand-primary); border-radius: 100px;
}
.doctor-bio { color: var(--color-text-secondary); font-size: 0.9rem; line-height: 1.7; margin: 0; }
</style>
